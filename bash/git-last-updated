#!/usr/bin/env bash
# Print the Unix timestamp of the last git commit that touched a path.

set -euo pipefail

usage() {
    echo "Usage: $(basename "$0") [-C <git-dir>] [-H | -u] <path>" >&2
    echo "  -C  Run git in this directory (default: current directory)" >&2
    echo "  -H  Output in human-readable format with local timezone" >&2
    echo "  -u  Output in human-readable format in UTC" >&2
    exit 1
}

git_dir=""
format="unix"

while getopts "C:Huh" opt; do
    case "$opt" in
        C) git_dir="$OPTARG" ;;
        H) format="human" ;;
        u) format="utc" ;;
        *) usage ;;
    esac
done
shift $((OPTIND - 1))

[[ $# -eq 1 ]] || usage

path="$1"

# Resolve the absolute path to look for submodule boundaries.
# A submodule root contains a .git file (not a directory).
base="${git_dir:-$PWD}"
abs_path="$base/$path"
git_root="$base"
rel_path="$path"
check="$abs_path"
while [[ "$check" != "$base" && "$check" != "/" ]]; do
    if [[ -f "$check/.git" ]]; then
        git_root="$check"
        rel_path="${abs_path#${check}/}"
        break
    fi
    check="$(dirname "$check")"
done

git_args=(-C "$git_root")

ts=$(git "${git_args[@]}" log -1 --format="%ct" -- "$rel_path")

if [[ -z "$ts" ]]; then
    echo "Error: no git history found for: $path" >&2
    exit 1
fi

case "$format" in
    human) date -d "@$ts" ;;
    utc)   date -u -d "@$ts" ;;
    *)     echo "$ts" ;;
esac
